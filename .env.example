# ── Django Core ───────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_SETTINGS_MODULE=trackwise_backend.settings.development

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://trackwise:password@localhost:5432/trackwise_db
# OR individual settings:
DB_NAME=trackwise_db
DB_USER=trackwise
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx
RAZORPAY_PLAN_ID_MONTHLY=plan_xxxx
RAZORPAY_PLAN_ID_YEARLY=plan_xxxx

# ── Email ─────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@trackwise.in

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,exp://localhost:19000

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Sentry (optional) ─────────────────────────────────────────
SENTRY_DSN=

# ── AWS S3 (optional) ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=trackwise-media
AWS_S3_REGION_NAME=ap-south-1
